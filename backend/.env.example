# --- Server ---
NODE_ENV=development
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173
BACKEND_ORIGIN=http://localhost:5000

# --- Database ---
DB_URI=mongodb://localhost:27017/shelfqueue

# --- Redis (rate limits, lockouts, token revocation list) ---
REDIS_URL=redis://localhost:6379

# --- JWT ---
# Separate secrets for access vs refresh tokens so one can be rotated without
# invalidating the other. Never commit real values — generate with e.g.
# `openssl rand -hex 64`.
JWT_SECRET=changeme_access_token_secret
JWT_REFRESH_SECRET=changeme_refresh_token_secret

# --- CSRF ---
# Separate secret from the JWT ones — used to HMAC-sign session-bound CSRF
# tokens (Phase 14). Generate with e.g. `openssl rand -hex 32`.
CSRF_SECRET=changeme_csrf_secret

# --- Google OAuth (login) ---
GOOGLE_OAUTH_CLIENT_ID=changeme_google_client_id
GOOGLE_OAUTH_CLIENT_SECRET=changeme_google_client_secret

# --- MFA secret encryption (AES-256-GCM key, 32 bytes hex) ---
MFA_ENCRYPTION_KEY=changeme_32_byte_hex_key

# --- CAPTCHA (hCaptcha / reCAPTCHA v2) ---
CAPTCHA_SECRET=changeme_captcha_secret

# --- Ethereal Email (free disposable test SMTP — no real delivery, coursework only) ---
# Used only as a fallback when SMTP_HOST below is not set.
ETHEREAL_EMAIL=changeme_ethereal_email
ETHEREAL_PASSWORD=changeme_ethereal_password

# --- Real SMTP delivery (optional — set SMTP_HOST to enable) ---
# For Gmail: smtp.gmail.com, port 587, SMTP_USER = your Gmail address,
# SMTP_PASSWORD = a 16-character App Password (Google Account > Security >
# App passwords — requires 2-Step Verification enabled first). Regular
# account passwords will not work.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- IP allow-list (comma-separated) that bypasses IP-based brute-force blocking ---
ALLOWED_IPS=

# --- Device binding on refresh (User-Agent + client device id fingerprint) ---
# Off by default — can be too strict for some legitimate clients.
DEVICE_BINDING_ENABLED=false

# --- Waitlist offer window (Phase 19) ---
WAITLIST_OFFER_HOURS=48
WAITLIST_SWEEP_INTERVAL_MS=300000

# --- Loan period / overdue sweep (Phase 20) ---
LOAN_PERIOD_DAYS=14
OVERDUE_SWEEP_INTERVAL_MS=300000

# --- Password expiry (Phase 24) ---
PASSWORD_EXPIRY_DAYS=90

# --- WebAuthn / passkeys (Phase 25) ---
# RP ID must be a bare domain (no scheme/port), matching FRONTEND_ORIGIN's host.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=ShelfQueue
