# Base URL the frontend uses to reach the backend API
VITE_API_BASE_URL=http://localhost:5000

# --- Local HTTPS (optional — see docs/https-local-dev.md) ---
# Leave both blank to serve plain HTTP (the default, and what CI uses).
# Set both to switch Vite's dev server to HTTPS via a mkcert-issued
# cert/key — also update VITE_API_BASE_URL above to https:// once you do.
SSL_CERT_PATH=
SSL_KEY_PATH=

# hCaptcha / reCAPTCHA v2 site key (public, safe to expose client-side)
VITE_CAPTCHA_SITE_KEY=changeme_captcha_site_key

# Google OAuth client id (public, safe to expose client-side)
VITE_GOOGLE_OAUTH_CLIENT_ID=changeme_google_client_id
